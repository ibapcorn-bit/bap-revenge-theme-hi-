      inset calc(-2px * var(--lx)) calc(-2px * var(--ly)) 0px -2px color-mix(in srgb, var(--c-light) calc(var(--glass-reflex-light) * 80%), transparent),
      inset calc(-3px * var(--lx)) calc(-8px * var(--ly)) 1px -6px color-mix(in srgb, var(--c-light) calc(var(--glass-reflex-light) * 60%), transparent),
      inset calc(-0.3px * var(--lx)) calc(-1px * var(--ly)) 4px 0px color-mix(in srgb, var(--c-dark) calc(var(--glass-reflex-dark) * 12%), transparent),
      inset calc(-1.5px * var(--lx)) calc(2.5px * var(--ly)) 0px -2px color-mix(in srgb, var(--c-dark) calc(var(--glass-reflex-dark) * 20%), transparent),
