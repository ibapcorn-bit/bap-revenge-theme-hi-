{
  "theme_metadata": {
    "name": "Translucence",
    "version": "2.0.0",
    "description": "A translucent/frosted glass Discord theme",
    "author": "CapnKitten",
    "website": "http://github.com/CapnKitten",
    "source": "https://github.com/CapnKitten/BetterDiscord/blob/master/Themes/Translucence/css/source.css",
    "donate": "https://paypal.me/capnkitten",
    "invite": "jzJkA6Z"
  },
  "root_variables": {
    "app": {
      "bg": "url(https://i.ibb.co/WNrbr1Yz/Alpine-Amnesia.png)",
      "blur": "6px",
      "margin": "24px",
      "radius": "8px"
    },
    "accent": {
      "hue": 260,
      "saturation": "83%",
      "lightness": "72%",
      "opacity": 0.8,
      "text_color": "hsl(0,0%,0%)"
    },
    "layout": {
      "sidebar_color": "hsl(0,0%,0%,0.34)",
      "main_content_color": "hsl(0,0%,0%,0.27)"
    },
    "messages": {
      "color": "hsl(0,0%,0%,0.19)",
      "color_hover": "hsl(0,0%,0%,0.28)",
      "radius": "18px",
      "padding_top": "8px",
      "padding_side": "8px"
    },
    "replies": {
      "hue": 328,
      "saturation": "79%",
      "lightness": "64%",
      "opacity": 1
    },
    "textarea": {
      "color": "255,255,255",
      "alpha": 0.125,
      "alpha_focus": 0.165,
      "text_color": "hsl(0,0%,100%)",
      "radius": "28px"
    },
    "cards": {
      "color": "hsl(0,0%,100%,0.14)",
      "color_hover": "hsl(0,0%,100%,0.18)",
      "color_select": "hsl(0,0%,100%,0.21)",
      "radius": "18px"
    },
    "buttons": {
      "height": "32px",
      "padding": "16px",
      "action_color": "hsl(0,0%,0%)",
      "radius": "16px"
    },
    "popouts": {
      "color": "hsl(0,0%,0%,0.46)",
      "blur": "6px",
      "radius": "18px",
      "shadow": "0 20px 40px hsl(0,0%,0%,0.44)",
      "shadow_border": "inset 0 1px 1px hsl(0,100%,100%,0.35), inset 0 -1px 2px hsl(0,0%,0%,0.25), inset 0 0 0 1px hsl(0,100%,100%,0.04)"
    },
    "effects": {
      "light_angle": "40deg",
      "liquid_glass_shadow": null
    }
  },
  "theme_dark_overrides": {
    "text": {
      "primary": "hsl(0,0%,100%)",
      "secondary": "hsl(0,0%,77%)",
      "default": "hsl(0,0%,86%)",
      "muted": "hsl(0,0%,72%)",
      "channels_default": "hsl(0,0%,73%)",
      "channel_icon": "hsl(0,0%,73%)",
      "strong": "hsl(0,0%,100%)",
      "brand": "hsl(var(--accent-hsl))",
      "link": "hsl(var(--accent-hsl))"
    },
    "icons": {
      "primary": "hsl(0,0%,96%)",
      "secondary": "hsl(0,0%,84%)",
      "tertiary": "hsl(0,0%,71%)"
    },
    "interactive": {
      "normal": "hsl(0,0%,79%)",
      "hover": "hsl(0,0%,91%)",
      "active": "hsl(0,0%,100%)",
      "muted": "hsl(0,0%,43%)"
    },
    "modifiers": {
      "hover": "hsl(0,0%,100%,0.075)",
      "active": "hsl(0,0%,100%,0.1)",
      "selected": "hsl(0,0%,100%,0.125)",
      "accent": "hsl(0,0%,100%,0.175)",
      "primary": "transparent"
    }
  }
}
