      inset calc(2px * var(--lx)) calc(-4.5px * var(--ly)) 1px -4px color-mix(in srgb, var(--c-dark) calc(var(--glass-reflex-dark) * 10%), transparent);
}

@supports (color: color-mix(in lch, red, blue)) {
  .theme-dark {
    /* TEXT COLOR SETTINGS */
    --text-primary: hsl(0,0%,100%);
    --text-secondary: hsl(0,0%,77%);
    --text-default: hsl(0,0%,86%);
    --text-muted: hsl(0,0%,72%);
    --channels-default: hsl(0,0%,73%);
    --channel-icon: hsl(0,0%,73%);
    --text-strong: hsl(0,0%,100%);
    /* ICON COLOR SETTINGS */
    --icon-primary: hsl(0,0%,96%);
    --icon-secondary: hsl(0,0%,84%);
    --icon-tertiary: hsl(0,0%,71%);
    /* INTERACTIVE COLOR SETTINGS */
    --interactive-normal: hsl(0,0%,79%);
    --interactive-hover: hsl(0,0%,91%);
    --interactive-active: hsl(0,0%,100%);
    --interactive-muted: hsl(0,0%,43%);
