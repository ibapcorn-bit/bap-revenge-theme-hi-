  --mention-lightness: var(--accent-lightness);
  --mention-hsl: var(--mention-hue),calc(var(--mention-saturation) * var(--saturation-factor)),var(--mention-lightness);
  --mention-opacity: 1;
  /* REPLY HSL COLOR SETTINGS */
  --reply-hue: 328;
  --reply-saturation: 79%;
  --reply-lightness: 64%;
  --reply-hsl: var(--reply-hue),calc(var(--reply-saturation) * var(--saturation-factor)),var(--reply-lightness);
  --reply-opacity: 1;
  /* MESSAGE COLOR SETTINGS */
  --message-color: hsl(0,0%,0%,0.19);
  --message-color-hover: hsl(0,0%,0%,0.28);
  --message-radius: var(--app-radius);
  --message-padding-top: 8px;
  --message-padding-side: 8px;
  --notification-color: hsl(0,0%,100%);
